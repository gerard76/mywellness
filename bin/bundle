#!/usr/bin/env ruby
# frozen_string_literal: true

#
# This file was generated by Bundler.
#
# The application 'bundle' is installed as part of a gem, and
# this file is here to facilitate running it.
#

require "rubygems"

m = Module.new do
  module_function

  def invoked_as_script?
    File.expand_path($0) == File.expand_path(__FILE__)
  end

  def env_var_version
    ENV["BUNDLER_VERSION"]
  end

  def cli_arg_version
    return unless invoked_as_script?
    return unless ARGV.first&.start_with?("_")
    return unless ARGV.first&.end_with?("_")
    Gem::Version.new(ARGV.first[1..-2])
  rescue ArgumentError
    nil
  end

  def gemfile
    gemfile = ENV["BUNDLE_GEMFILE"]
    return Pathname.new(gemfile) if gemfile && !gemfile.empty?
    Pathname.pwd.expand_path.ascend do |directory|
      gemfile = directory.join("Gemfile")
      return gemfile if gemfile.file?
    end
    raise "No Gemfile found"
  end

  def bundler_version
    @bundler_version ||= env_var_version || cli_arg_version || lockfile_version
  end

  def lockfile_version
    return unless (lockfile_path = lockfile)
    lockfile_contents = lockfile_path.read
    return unless (versions = lockfile_contents.scan(/^BUNDLED WITH\n   (\d+\.\d+\.\d+)$/))
    return if versions.empty?
    Gem::Version.new(versions.last.first)
  rescue Errno::ENOENT
    nil
  end

  def lockfile
    gemfile_path = gemfile
    lockfile_path = gemfile_path.sub(/(\.\w+)?$/, ".lock")
    return lockfile_path if lockfile_path.file?
  end

  def load_bundler!
    $LOAD_PATH.unshift(*Dir[Gem.paths.home + "/gems/bundler-*/lib"])
    if bundler_version
      activate_bundler
    else
      require "bundler"
    end
  end

  def activate_bundler
    gem_error = activation_error_handling do
      gem "bundler", "= #{bundler_version}"
    end
    return if gem_error.nil?
    require_error = activation_error_handling do
      require "bundler/version"
    end
    return if require_error.nil? && Gem::Version.new(Bundler::VERSION) == bundler_version
    warn "Activating bundler (#{bundler_version}) failed:\n#{gem_error.message}\n\nTo install the version of bundler this project requires, run `gem install bundler -v '#{bundler_version}'`"
    exit 42
  end

  def activation_error_handling
    yield
    nil
  rescue StandardError, LoadError => e
    e
  end
end

m.load_bundler!

if m.invoked_as_script?
  load Gem.bin_path("bundler", "bundle")
end

# SQLite databases (contain personal workout data)
/storage/*.sqlite3
/storage/*.sqlite3-journal
/storage/*.sqlite3-shm
/storage/*.sqlite3-wal
/db/*.sqlite3
/db/*.sqlite3-journal
/db/*.sqlite3-shm
/db/*.sqlite3-wal

# Temp files
/tmp/*
!/tmp/.keep
/tmp/pids/*
!/tmp/pids/.keep

# Logs
/log/*
!/log/.keep

# Environment secrets
.env
.env.*

# macOS
.DS_Store

# Ruby/bundler
.bundle/
vendor/bundle/

# Node
/node_modules
/yarn-error.log

# Rails
/public/assets
/public/packs
*.orig